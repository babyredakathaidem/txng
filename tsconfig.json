{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["resources/js/*"],
      "ziggy-js": ["./vendor/tightenco/ziggy"]
    },
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "preserve",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["resources/js/**/*"],
  "exclude": ["node_modules", "public"]
}